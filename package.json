{
  "name": "vibe-editor",
  "version": "1.6.4",
  "private": true,
  "description": "Tauri ベースの Claude Code / Codex 専用エディタ",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "cargo tauri dev",
    "build": "cargo tauri build",
    "dev:vite": "vite",
    "build:vite": "vite build",
    "typecheck": "tsc -b --force",
    "lint": "eslint .",
    "test": "vitest run",
    "lint:safe-load": "node build/check-safe-load.mjs",
    "lint:file-size": "node build/check-file-size-ratchet.mjs",
    "lint:command-result": "node build/check-command-result.mjs",
    "test:watch": "vitest",
    "icons": "node build/generate-icons.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "dompurify": "^3.4.0",
    "lucide-react": "^1.11.0",
    "marked": "^18.0.2",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.10",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "dompurify": "$dompurify",
    "postcss": "^8.5.10",
    "esbuild": "^0.28.0"
  }
}
