{
  "name": "vibe-editor",
  "version": "1.6.7",
  "private": true,
  "description": "Tauri ベースの Claude Code / Codex 専用エディタ",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "cargo tauri dev",
    "build": "cargo tauri build",
    "dev:vite": "vite",
    "build:vite": "vite build",
    "typecheck": "tsc -b --force",
    "lint": "eslint .",
    "test": "vitest run",
    "lint:safe-load": "node build/check-safe-load.mjs",
    "lint:file-size": "node build/check-file-size-ratchet.mjs",
    "lint:css-vars": "node build/check-css-custom-properties.mjs",
    "lint:dependency-dedupe": "node build/check-dependency-dedupe.mjs",
    "lint:release-workflow": "node build/check-release-workflow.mjs",
    "lint:command-result": "node build/check-command-result.mjs",
    "lint:team-events": "node build/check-team-event-payloads.mjs",
    "lint:team-event-types": "node build/check-team-event-types.mjs",
    "generate:team-event-types": "node build/check-team-event-types.mjs --write",
    "test:watch": "vitest",
    "icons": "node build/generate-icons.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.11.0",
    "dompurify": "^3.4.11",
    "lucide-react": "^1.11.0",
    "marked": "14.0.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^26.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.1.4",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "dompurify": "$dompurify",
    "postcss": "^8.5.10",
    "esbuild": "^0.28.0"
  }
}
